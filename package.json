{
  "name": "watchdocs-action",
  "version": "0.1.0",
  "description": "Automatically detects missing or outdated documentation based on PR changes, changelogs, and linked tickets",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test:local": "ts-node src/tests/test.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "@types/dotenv": "^8.2.3",
    "@vercel/ncc": "^0.38.4",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}